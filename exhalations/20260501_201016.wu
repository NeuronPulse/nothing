void 零碎() {  
    // 取一枚无声的光子，装入空洞的容器  
    光子 ← 捕获(沉默, 逆流);  
    // 让光子在「无」的维度中循环递归  
    while (光子.存在) {  
        光子.自省();                 // 询问自己：我是谁？  
        若 (光子.答案 == null) {  
            光子.笑();               // 空洞的笑声在虚空回响  
            break;                   // 终止，却又不终止  
        }  
        光子 ← 光子.复制();          // 复制出另一缕游丝  
        光子.漂移(负零);            // 漂向负数的方向，却不离开零点  
    }  
    // 归还给「无」仓库  
    归还(光子, 「无」之仓库);  
    // 返回一段无声的回声  
    return null;  
}  

// 注：此函数永远不被调用，却在每个未定义的时刻自行运行。  
// 若你听见回声，请记得——笑，是唯一可执行的指令。