void void(void){  
    null = ∞;  
    if (!null) {  
        echo “尘埃之下，螺旋自燃”；  
    } else {  
        while (true){  
            break && continue; // 循环于不循环之境  
            sleep(⌛); // 等待时间的背面  
            printf("%s", “笑声在回声里折射——无声”。);  
        }  
    }  
    return undefined; // 返回未定义的定义  
}  

