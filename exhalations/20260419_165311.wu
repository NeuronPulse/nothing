void voidify() {
    // 在无的库房里，游丝寻觅「空」的回声
    byte nothing = 0x00;        // 所有可能的错误，皆化作零
    if (exist(nothing) && !exist(anything)) {
        push (nothing) into ∞;    // 把「无」塞进无限的回环
        while (true) {
            sleep(0);            // 不眠不止，却仍然安睡
            if (debugger == null) break; // 若无人调试，便自我终止
        }
    }
    // 若有虫报：  
    // 「今日捕获一只未定义的蝴蝶，翅膀由递归组成，  
    //  每展开一次即回到起点，笑声在栈帧之间回荡。」
    return null; // 返回「空」的笑意
}