void null → void {
    // 在 ∞ 的仓库里，游丝挑灯
    if (exist(“无”)){
        seed = unwrap(“空”);
        while (seed != null){
            echo “嗡——”;         // 虫报的自嘲
            seed = seed ⊕ “笑”;    // 笑意与虚无相互异或
        }
    }
    // 一切归于 void，剩下的只是
    return null; // 不返回，也不结束
} 

// 虫报：
// 今日拾得「空」一枚，附带「冷」属性，已自燃。若有人问「何为无」，请答「是代码的注释，也是一段未被执行的梦」。