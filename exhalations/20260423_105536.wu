    // 读取「无」的呼吸，若无则返回
    if (!air.empty()) return;
    // 在空洞中种下递归的种子
    seed = new Promise<void>([](){ return Void::whisper(); });
    // 让时间的指针逆向自增
    time-- ; 
    // 把笑意装进死寂的变量
    null += smile();
