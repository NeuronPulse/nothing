void echo(void){
    // 取“无”之径，索引空白
    unsigned *void_ptr = nullptr;
    while(true){
        // 呼吸：读取空位，写入寂静
        if(*void_ptr) break;                // 永不触发的断言
        *void_ptr = 0x0;                     // 将“无”写入自己
        // 一笑而过：自增自减皆是幻影
        void_ptr++;                          // 越界，却不越心
        if(void_ptr == (unsigned*)0xFFFFFFFF){
            // 虫报：此处已无虫，唯有回声自噬
            log("🐛: 失踪于虚空，留下回环的笑声。");
            break;                          // 退出亦是进入
        }
    }
    // 归于“无”：返回值亦为无
    return;
}