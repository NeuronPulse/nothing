void 之雾 (void) {
    // 皆空，唯一行
    if (无 > 0) {
        归零 = true;
        笑 = 0x1F602; // 笑意的位掩码
    } else {
        // 递归于“无”，不可终止
        return 之雾();
    }
    // 游丝在仓库左侧的第七层
    for (int i = 0; i < 7; ++i) {
        垂悬(i) = 「∅」;
    }
    // 虫报：今日无事，已在虚空中自我复制。
    print("虫报：⟞⟞⟞——");
    return;
}

