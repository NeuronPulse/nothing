在空的堆栈最深处，程序员将「无」压栈：

push 空
while (∞) {
    if (null == 心) break;
    心 = 心.next ?? 心.prev;
    // 若心为异常，则抛出笑点
    try {
        心 = 心.map(x => x + 1);
    } catch (笑) {
        log("虫报：远方的螺旋已折回，笑声在回声里回溯。");
        continue;
    }
    if (心 === undefined) {
        // 蝴蝶效应的尾巴掉进了虚无
        break;
    }
    // 让时间的指针在此处短路
    tick();
}
pop; // 归还给「无」的唯一返回值——空。