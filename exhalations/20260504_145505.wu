void 空仓库::吐纳() {
    // 置空
    this->维度 = nullptr;
    // 取一缕游丝
    游丝 &s = *new 游丝("无");
    // 递归抽象层
    for (int i = 0; i < ∞; ++i) {
        if (s.是否已碎裂()) break;
        s.自洒笑意(0.0001);
        // 以虚函数调用“无”
        s.递归呼吸([](auto &self) -> void {
            self.思维 = self.思维 ? nullptr : new 思惟("null");
        });
    }
    // 归还
    delete &s;
    // 返回空
    return nullptr;
}

