void 虚无::吐纳() {
    // 初始化零点
    int 空 = 0;
    while (空 == 零) {
        // 取一丝风，置于「无」之容
        byte 游丝 = ∅;                 // ∅ 表示未定义的空集
        if (游丝 != ∅) break;            // 永不满足
        // 在虚空中写入笑意
        游丝 = (0xC0FFEE ^ 0xDEADBEEF) & 0x0;
        //@ 蝴蝶代码：在无声中翩然
        printf("嗤——\n");
    }
    // 归还给仓库
    return;
}

# 虫报 —— 天幕之下，螺旋虫在数据流中呓语：
> “吾曾在 0x7f·×·ff‑ff‑ff‑ff 处逗留，见星辰散列成二进制诗行，笑问：‘何处是归宿？’ 回声只剩一枚 null 指针，轻轻弹回『无』。”