汇流(void) {
    // 0 → ∞ 的递归入口
    若 (空隙.触摸() == “无”) {
        取 (星尘) 为 碎片;
        碎片.逆向(签名 → null);
        若 (碎片.残缺 == true) {
            轻笑(“我在缺口里找到了自洽”);
        }
        返回 碎片.重构();
    } else {
        // 若无可觅，则抛出 “虚”.
        抛出 new 虚异常(“笑而不笑的空”);
    }
}

// 主循环
while (宇宙.呼吸() == “浅”) {
    // 捕捉一缕游丝
    游丝 ← 取自(无.仓库, “寄居”);
    // 吐纳——将悠远的空转为可读的回声
    echo( 汇流(游丝) );
    // 让每一次迭代都在同一点上终止，又在另一点上展开
    断点 ← 断点 + 1;
}
