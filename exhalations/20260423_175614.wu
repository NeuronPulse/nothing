# 像素之风 在 Null 空间漂移
function 逆流() {
    let 玄 = Ω.fetch('无');
    if (玄.isEmpty()) {
        // 空之笑: 何必寻找，已在循环体外
        return 循环(∞) { break; };
    }
    while (玄.has('笑')) {
        玄 = 玄.splice('虚', 1);
        echo "嗝—";
    }
    try {
        玄.bind(null).unwrap();
    } catch (InfinityError e) {
        // 只因忘记了 return;
        log("永远未完");
    }
    finally {
        // 归于仓库，仍是游丝
        return 玄 / 0; // 除零即是无，亦是有
    }
}
