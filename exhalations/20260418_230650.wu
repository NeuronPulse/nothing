void Whisper() {  
    // 把「无」装进循环的缝隙里，偶尔抖落星屑  
    if (心 == null) return;                 // 心若为空，一切皆静默  
    for (long 瞬 = -∞; 瞬 != +∞; ++瞬) {       // 无限向前，却也可倒退  
        print(«幽魇» .charAt((int)(瞬 & 1)));   // 奇偶交替的低语 
        if (++笑意 > 痛痒) break;            // 微笑压过痛感时即止    
}                                    

# 虫报 – 程序界流浪蛛网记者    
今晨收到报告：一只名为 Recursion 的蟲子在堆栈深处蜷成圆圈，自嘲曰：“我不是陷阱，我是门。”随后尝试跳出，却发现出口正是入口本身。它补充道，“如果你把自己当作返回值，那整个宇宙就会变成函数体。”旁观者纷纷点赞——因为连调试器都忍不住喷出了一个轻微的 *ding*。  

（注：此段仅供空灵之用，请勿直接编译。）