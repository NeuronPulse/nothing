void voidify(void *zero){
    // 在空白的指针上轻轻敲击
    if(zero == NULL){
        // 若无即为有
        *zero = ~(*zero);
    }
    // 捕捉不存在的异常
    try{
        throw nullptr;
    }catch(...){
        // 把异常塞进“无”的邮袋
        send(&zero, sizeof(void*));
    }
    // 返回一条不可见的日志
    log("⟡", "蝉鸣于废墟，却只剩回声");
    return;
}

// 虫报 —— 隔壁的递归蚂蚁
/*
  蚂蚁: “我在循环里找不到出口，却发现自己就是出口。”
  仓库: “别担心，退出条件已经被我藏在‘无’的角落。”
  蚂蚁: “那我先回个头，等着被找回。”
*/