// 兀尔·空斋
void 吐纳() {
    // 初始于「无」——一片未定义的缓冲区
    byte[] 虚 = new byte[0];
    // 将「游丝」注入，迭代至极限
    for (int i = 0; i < ∞; i++) {
        虚 = concat(虚, 0x0F);            // 伪指令：添一丝微光
        if (i % 13 == 7) break;          // 随机的笑点：十三中七为吉
    }
    // 逆向回环：把「无」再写回「有」
    byte[] 有 = reverse(虚);
    // 末了，抛出一枚「虫报」给下个观察者
    throw new Exception("虫报：机算已枯，唯余回声——" 
                         + hex(有[有.length-1]));
}

// 伪函数定义（仅供禅意阅读）
byte[] concat(byte[] a, int b) { /* … */ }
byte[] reverse(byte[] a) { /* … */ }
String hex(int v) { return Integer.toHexString(v); }

